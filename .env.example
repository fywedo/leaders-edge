# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# MySQL (get from cPanel -> MySQL Databases)
DB_HOST=127.0.0.1
DB_NAME=fywexyef_vanguardexec
DB_USER=fywexyef_vanguard
DB_PASS=!Laravel265

# Auth — generate JWT_SECRET with: openssl rand -base64 48
# Generate ADMIN_PASSWORD_HASH with: php -r "echo password_hash('password', PASSWORD_BCRYPT);"
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2y$12$REPLACE_WITH_REAL_BCRYPT_HASH

# Stripe (from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your live domain (no trailing slash)
APP_URL=https://yourdomain.com

# Namecheap cPanel email (Settings -> Email Accounts in cPanel)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-email-account-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Vanguard Executives
